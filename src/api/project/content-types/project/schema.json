{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project",
    "description": "Portoflio Projects"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "web",
        "app",
        "branding"
      ],
      "required": true,
      "default": "web"
    },
    "year": {
      "type": "integer",
      "required": true
    },
    "month": {
      "type": "integer",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "rarity": {
      "type": "enumeration",
      "enum": [
        "common",
        "rare",
        "ultra"
      ],
      "required": true,
      "default": "common"
    },
    "element_type": {
      "type": "enumeration",
      "enum": [
        "fire",
        "water",
        "grass",
        "electric",
        "psychic",
        "dark",
        "steel",
        "dragon"
      ],
      "required": true,
      "default": "electric"
    },
    "level_text": {
      "type": "string"
    },
    "link": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "abilities": {
      "type": "component",
      "repeatable": true,
      "component": "project.ability"
    },
    "tech_stack": {
      "type": "json"
    }
  }
}
